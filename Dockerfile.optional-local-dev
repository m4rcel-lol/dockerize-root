# Optional local dev container only. Root production bots are hosted by Root.
FROM node:22-alpine

WORKDIR /app

COPY server/package*.json ./
RUN npm install

COPY server/tsconfig.json ./
COPY server/src ./src
COPY root-manifest.json ./root-manifest.json

RUN npm run build

ENV NODE_ENV=production
CMD ["npm", "run", "bot"]
