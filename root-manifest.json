  "version": "1.0.0",
  "package": {
    "server": {
      "launch": "dist/main.js",
      "deploy": ["dist"],
      "nodeModules": ["node_modules"]
    }
  },
  "permissions": {
    "community": {
      "manageRoles": true,
      "createChannelGroup": true
    },
    "channel": {
      "fullControl": true,
      "createMessage": true,
      "viewMessageHistory": true,
      "createMessageReaction": true,
      "voiceMuteOther": true,
      "voiceDeafenOther": true,
      "voiceKick": true,
      "createFile": true,
      "manageFiles": true,
      "viewFile": true
    }
  }
}
